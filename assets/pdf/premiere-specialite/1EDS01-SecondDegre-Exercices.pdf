\MethodeQRCodeVSmall{https://www.youtube.com/watch?v=JcT6kph74O0}{Déterminer la forme canonique d'une fonction polynôme du second degré}{Exercice 1}


\begin{exercice}
	Déterminer la forme canonique de chaque trinôme.

    \begin{center}
    \begin{tabularx}{\linewidth}{X X X}
    \textbf{a)} $x^2+6x-8$ & \textbf{b)} $2x^2+6x+4$ & \textbf{c)} $3x^2+12x+12$ \\
    \textbf{d)} $x^2-5x+3$ & \textbf{e)} $-x^2+x+3$ & \textbf{f)} $-x^2+7x-10$
    \end{tabularx}
    \end{center}

	
\end{exercice}



\MethodeQRCodeVSmall{https://www.youtube.com/watch?v=youUIZ-wsYk}{Résoudre une équation du second degré}{Exercices 2--3}


\begin{exercice}
Résoudre dans $\R$ les équations suivantes:

    \begin{center}
    \begin{tabularx}{\linewidth}{X X}
    \textbf{a)} $x^2-x-6=0$ & \textbf{f)} $1-t-2t^2=0$  \\
    \textbf{b)} $x^2+2x-3=0$ & \textbf{g)} $x^2+x-1=0$ \\
    \textbf{c)} $x^2-x+2=0$ & \textbf{h)} $2x^2+12x+18=0$ \\
    \textbf{d)} $-x^2+2x-1=0$ & \textbf{i)} $-3x^2+7x+1=0$ \\
    \textbf{e)} $y^2+5y-6=0$ & \textbf{j)} $x^2+3\sqrt{2}x+4=0$ \\
    \end{tabularx}
    \end{center}
	
\end{exercice}

\begin{exercice}
Résoudre dans $\R$ les équations suivantes:

    \begin{center}
    \begin{tabularx}{\linewidth}{X X}
    \textbf{a)} $3x^2-4\sqrt{7}x-12=0$ & \textbf{d)} $2x-x^2-2=0$  \\
    \textbf{b)} $\sqrt{2}t^2-3t+\sqrt{2}=0$ & \textbf{e)} $x^3-8x^2+12x=0$ \\
    \textbf{c)} $x^2-(2+\sqrt{3})x+1+\sqrt{3}=0$ & \textbf{f)} $(2x-1)^2+3=0$ \\
    \end{tabularx}
    \end{center}
	
\end{exercice}

\begin{exercice}
\'Ecrire les trinômes suivants sous la forme d'un produit de facteurs.

    \begin{center}
    \begin{tabularx}{\linewidth}{X X}
    \textbf{a)} $x^2-7x+10$ & \textbf{c)} $2x^2-5x+2$ \\
    \textbf{b)} $-3x^2+4x+4$ & \textbf{d)} $-\dfrac{1}{2}x^2-\dfrac{1}{2}x+1$ \\
    \end{tabularx}
    \end{center}

	
\end{exercice}

\MethodeQRCodeVSmall{https://www.youtube.com/watch?v=UTcryCyG29s}{Utiliser la somme et le produit des racines}{Exercices 5--6--7}


\begin{exercice}
	\begin{enumerate}
	  \item Vérifier que $-1$ est solution de l'équation $x^2+3x+2=0$.
	  \item Quelle est la somme et le produit des racines?
	  \item En déduire l'autre solution.
	\end{enumerate}
\end{exercice}

\begin{exercice}
Trouver une racine évidente des équations suivantes et en déduire l'autre solution sans calculer le discriminant.


    \begin{center}
    \begin{tabularx}{\linewidth}{X X}
    \textbf{a)} $x^2-7x+6=0$ & \textbf{e)} $x^2+x-6=0$ \\
    \textbf{b)} $-3x^2+2x+5=0$ & \textbf{f)} $x^2+5x+4=0$ \\
    \textbf{c)} $x^2+3x-10=0$ & \textbf{g)} $2x^2+x\sqrt{5}-15=0$ \\
    
    \textbf{d)} $x^2-x\sqrt{2}-4=0$ & \textbf{h)} $x^2-8x+15=0$ \\
    \end{tabularx}
    \end{center}

\end{exercice}

\begin{exercice}
Soit $m$ un réel donnée différent de $1$.

On considère l'équation $E_m: (m-1)x^2-2x+1-m=0$.

Démontrer que pour tout $m\neq 1$, l'équation $E_m$ admet deux solutions $x_1$ et $x_2$ de signe contraire.	
\end{exercice}


\MethodeQRCodeVSmall{https://www.youtube.com/watch?v=AEL4qKKNvp8}{Résoudre une inéquation du second degré}{Exercice 8}

\begin{exercice}
	Résoudre les inéquations suivantes:
	
    \begin{center}
    \begin{tabularx}{\linewidth}{X X}
    \textbf{a)} $ x^2-3x+2>0$ & \textbf{g)} $x(x-2)<0 $ \\
    \textbf{b)} $ x^2+4\geqslant 0$ & \textbf{h)} $ x^2+7x+12\geqslant 0$ \\
    \textbf{c)} $ m^2+m-20\leqslant 0$ & \textbf{i)} $ -2x^2-x+4 >0$ \\
    \textbf{d)} $ x^2-x+1 <0 $ & \textbf{j)} $ 2x^2-24x+72 \leqslant 0$ \\
    \textbf{e)} $ 3x^2+18x+27>0$ & \textbf{k)} $ x^2+4x-12<0$ \\
    \textbf{f)} $ -x^2-9 \geqslant 0 $ & \textbf{l)} $ x^2-5x+7>0$ \\
 
    \end{tabularx}
    \end{center}

\end{exercice}


\MethodeQRCodeVSmall{https://www.youtube.com/watch?v=aFqvq0rB_PY}{Résoudre une équation bicarrée}{Exercice 9}

\begin{exercice}
	
	Résoudre les équations bicarrées suivantes:
	
    \begin{center}
	    \begin{tabularx}{\linewidth}{X X}
		    \textbf{a)} $4x^4-5x^2+1=0$ & \textbf{d)} $4x^2-35-\dfrac{9}{x^2}=0$ \\
		    \textbf{b)} $2x^4-x^2+1=0$ & \textbf{e)} $-2x^4+12x^2-16=0$ \\
		    \textbf{c)} $x^4-8x^2-9=0$ & \textbf{f)} $x^4+5x^2+4=0$ \\
	    \end{tabularx}
    \end{center}
\end{exercice}


\begin{exercice}
	
	Résoudre les équations suivantes:
	
    \begin{center}
	    \begin{tabularx}{\linewidth}{X X}
		    \textbf{a)} $ \dfrac{x^2+2x+1}{x+1}=2x-1$ & \textbf{c)} $ \dfrac{1}{x+2}-\dfrac{2}{2x-5}=\dfrac{9}{4}$ \\
		    \textbf{b)} $ \dfrac{3x}{x+2}-\dfrac{x+1}{x-2}=-\dfrac{11}{5}$ & \textbf{d)} $\dfrac{3x^2+10x+8}{x+2}=2x+5$ \\
	    \end{tabularx}
    \end{center}
\end{exercice}

\begin{exercice}
	
	Résoudre les inéquations suivantes:
	
    
    \begin{center}
	    \begin{tabularx}{\linewidth}{X X}
		    \textbf{a)} $ \dfrac{2x^2+5x+3}{x^2+x-2}>0$ & \textbf{c)} $(x+3)(x-1)<2x+6$ \\
		    \textbf{b)} $ (2x-1)^2>(x+1)^2$ & \textbf{d)} $\dfrac{x+3}{1-x}\geqslant -5$ \\
	    \end{tabularx}
    \end{center}
\end{exercice}

\begin{exercice}
Après un changement de variable approprié, résoudre les équations suivantes:

    \begin{center}
	    \begin{tabularx}{\linewidth}{X X}
		    \textbf{a)} $ (x^2-x)^2=14(x^2-x)-24$ & \textbf{c)} $x-3\sqrt{x}-4=0$ \\
	    \end{tabularx}
    \end{center}

	
\end{exercice}


\begin{exercice}
Résoudre les systèmes suivants:

    \begin{center}
	    \begin{tabularx}{\linewidth}{X X}
