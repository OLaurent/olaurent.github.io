\begin{exercice}
On considère un trinôme du second degré $P$ défini sur $\R$ par $P(x)=ax^2+bx+c$.

\begin{tabular}{cc}
\begin{minipage}{6cm}
	
  La représentation graphique de $P$ est donnée ci-contre. En utilisant celle-ci, choisir pour chacune des questions la seule réponse exacte, en justifiant.
\end{minipage}

 & 
\begin{minipage}{9cm}
	\includegraphics[width=8cm]{img/CourbeP.png}
\end{minipage}
\\
\end{tabular}

\begin{enumerate}
  \item Le coefficient $a$ est:
       \begin{center}
	    \begin{tabularx}{\linewidth}{X X X}
		    \textbf{a)} strictement positif & \textbf{b)} strictement négatif & \textbf{a)} on ne peut pas savoir \\
	    \end{tabularx}
    \end{center}

  \item Le coefficient $b$ est:
       \begin{center}
	    \begin{tabularx}{\linewidth}{X X X}
		    \textbf{a)} strictement positif & \textbf{b)} strictement négatif & \textbf{a)} on ne peut pas savoir \\
	    \end{tabularx}
    \end{center}

  \item Le coefficient $c$ est:
       \begin{center}
	    \begin{tabularx}{\linewidth}{X X X}
		    \textbf{a)} strictement positif & \textbf{b)} strictement négatif & \textbf{a)} on ne peut pas savoir \\
	    \end{tabularx}
    \end{center}

  \item Le coefficient $\Delta$ est:
       \begin{center}
	    \begin{tabularx}{\linewidth}{X X X}
		    \textbf{a)} strictement positif & \textbf{b)} strictement négatif & \textbf{a)} on ne peut pas savoir \\
	    \end{tabularx}
    \end{center}

  \item La somme $a+b+c$ est:
       \begin{center}
	    \begin{tabularx}{\linewidth}{X X X}
		    \textbf{a)} strictement positive & \textbf{b)} strictement négative & \textbf{a)} on ne peut pas savoir \\
	    \end{tabularx}
    \end{center}

\end{enumerate}


	
\end{exercice}


